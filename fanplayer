-- refresh
local function refresh()
	for _,v in ipairs(list:GetChildren()) do
		if v:IsA("TextLabel") and v~=empty then
			v:Destroy()
		end
	end
	if #queue==0 then
		empty.Visible=true
		return
	end
	empty.Visible=false
	for i,v in ipairs(queue) do
		local t=Instance.new("TextLabel",list)
		t.Size=UDim2.new(1,-10,0,24)
		t.Font=font
		t.TextSize=14
		t.TextXAlignment=Enum.TextXAlignment.Left

if playing and i==current then
	t.Text=" ▶ "..i..". "..v.name -- aw man i wanted emojis
else
	t.Text=i..". "..v.name
end

		-- default state
		t.BackgroundTransparency=1
		t.TextColor3=sub
		-- ONLY highlight if currently playing
		if playing and i==current then
			t.BackgroundTransparency=0
			t.BackgroundColor3=Color3.fromRGB(60,60,60)
			t.TextColor3=text
		end
	end
end

-- play
local function playSong(i)
	local sng=queue[i]
	if not sng then return end
	current=i
	local asset=getAudio(sng.name..".mp3",sng.url)
	if not asset then return end
	sound:Stop()
	sound.SoundId=asset
	sound.TimePosition=0
	sound:Play()
	playing=true
	playBtn.Text="Pause"
	now.Text="Now Playing: "..sng.name
	refresh()
end

-- controls
playBtn.MouseButton1Click:Connect(function()
	if current==0 then return end
	local sng=queue[current]
	if not sng then return end
	if playing then
		sound:Pause()
		playing=false
		playBtn.Text="Play"
		now.Text="Paused: "..sng.name
	else
		sound:Resume()
		playing=true
		playBtn.Text="Pause"
		now.Text="Now Playing: "..sng.name
	end
	refresh()
end)

nextBtn.MouseButton1Click:Connect(function()
	if #queue==0 then return end
	current=current%#queue+1
	playSong(current)
end)

prevBtn.MouseButton1Click:Connect(function()
	if #queue==0 then return end
	current=(current-2)%#queue+1
	playSong(current)
end)

shuffleBtn.MouseButton1Click:Connect(function()
	if #queue==0 then return end
	playSong(math.random(1,#queue))
