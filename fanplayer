-- clean it out
local function cleanSongName(path)
	path = path:gsub("\\","/")
	path = path:match("Songs %(Fan Player%)/(.+)") or path
	path = path:gsub("%.mp3$","")
	return path
end

-- download it yoh
local function getAudio(n,u)
	local p = folder.."/"..n
	if isfile(p) then return getcustomasset(p) end

	local r = syn and syn.request or http and http.request or request or http_request
	local d

	if r then
		local s,x = pcall(function()
			return r({Url=u,Method="GET"})
		end)
		if s and x and x.StatusCode == 200 then d = x.Body end
	end

	if not d then
		local s,x = pcall(function()
			return game:HttpGet(u)
		end)
		if s and typeof(x) == "string" then d = x end
	end

	if not d or typeof(d) ~= "string" then return nil end

	writefile(p,d)
	return getcustomasset(p)
end

