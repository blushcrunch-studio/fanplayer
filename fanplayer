-- load
loadBtn.MouseButton1Click:Connect(function()
	queue={}
	for _,file in ipairs(listfiles(folder)) do
		local clean=cleanSongName(file)
		table.insert(queue,{
			name=clean,
			url="file://"..file
		})
	end
	current=0
	playing=false
	sound:Stop()
	now.Text="Loaded "..#queue.." songs, now press Next to play!"
	refresh()
end)

sound.Ended:Connect(function()
	if #queue==0 or current==0 then return end
	current=current%#queue+1
	playSong(current)
end) -- okay its done
