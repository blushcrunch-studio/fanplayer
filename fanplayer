-- play it, john!
local function playSong(i)
    local sng=queue[i]
    if not sng then return end

    current=i
    sound.SoundId=getAudio(sng.name..".mp3",sng.url)
    sound:Play()

    playing=true
    playBtn.Text="Pause"
    now.Text="Now Playing: "..sng.name
end

-- play it better, johnson!
playBtn.MouseButton1Click:Connect(function()
    if current==0 then return end

    if playing then
        sound:Pause()
        playing=false
        playBtn.Text="Play"
    else
        sound:Play()
        playing=true
        playBtn.Text="Pause"
    end
end)

-- ctrontorl
nextBtn.MouseButton1Click:Connect(function()
    if #queue==0 then return end
    current=current%#queue+1
    playSong(current)
end)

prevBtn.MouseButton1Click:Connect(function()
    if #queue==0 then return end
    current=(current-2)%#queue+1
    playSong(current)
end)

shuffleBtn.MouseButton1Click:Connect(function()
    if #queue==0 then return end
    playSong(math.random(1,#queue))
end)

-- add
addBtn.MouseButton1Click:Connect(function()
    if nameBox.Text=="" or urlBox.Text=="" then return end

    for _,v in ipairs(queue) do
        if v.name==nameBox.Text then return end
    end

    table.insert(queue,{
        name=nameBox.Text,
        url=urlBox.Text
    })

    nameBox.Text=""
    urlBox.Text=""

    refresh()
end)

-- one play and its gone lol
sound.Ended:Connect(function()
    if #queue>0 and current>0 then
        table.remove(queue,current)

        if current>#queue then current=1 end

        refresh()

        if #queue>0 then
            playSong(current)
        else
            current=0
            playing=false
            playBtn.Text="Play"
            now.Text="No song selected"
        end
    end
end)
