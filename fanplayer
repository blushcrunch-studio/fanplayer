local function SendCustomChat(msg, isSystem)
	local user = "Fan"

	local TextChatService = game:GetService("TextChatService")

	if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
		local channel = TextChatService:FindFirstChild("RBXGeneral", true)
		if channel then

			local finalMsg

			if isSystem then
				finalMsg = msg
			else
				finalMsg =
					"<font color='#A67A30'>"..user..":</font> "..
					"<font color='#FFFFFF'>"..msg.."</font>"
			end

			channel:DisplaySystemMessage(finalMsg)
		end
	end

	pcall(function()
		game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
			Text = isSystem and msg or (user .. ": " .. msg),
			Color = Color3.fromRGB(255,255,255),
			Font = Enum.Font.SourceSansBold
		})
	end)
end

