local function download(n,u)
    local p=folder.."/"..n
    if isfile(p)then return getcustomasset(p)end

    local r=syn and syn.request or http and http.request or request or http_request
    local d

    if r then
        local s,x=pcall(function()return r({Url=u,Method="GET"})end)
        if s and x and x.StatusCode==200 then d=x.Body end
    end

    if not d then
        local s,x=pcall(function()return game:HttpGet(u)end)
        if s then d=x end
    end

    writefile(p,d)
    return getcustomasset(p)
end

